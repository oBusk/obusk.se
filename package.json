{
    "name": "@obusk/obusk.se",
    "private": true,
    "version": "0.0.1",
    "description": "🙋‍♂🔧 My simple website",
    "keywords": [
        "personal",
        "vercel"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/oBusk/obusk.se.git"
    },
    "author": "Oscar Busk <oscar.busk@gmail.com>",
    "license": "ISC",
    "engines": {
        "node": "24.x"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "^24.13.0",
            "onFail": "download"
        }
    },
    "packageManager": "pnpm@10.28.2",
    "lint-staged": {
        "**/*.{ts,tsx,js,jsx}": [
            "eslint --fix"
        ],
        "**/*.{md,yml,yaml,json}": [
            "prettier  --ignore-path .prettierignore --write"
        ]
    },
    "simple-git-hooks": {
        "pre-commit": "pnpm run lint-staged"
    },
    "scripts": {
        "dev": "next",
        "build": "next build",
        "start": "next start",
        "type-check": "tsc",
        "lint": "eslint .",
        "postlint": "pnpm run prettier",
        "lint-fix": "eslint --fix .",
        "prettier": "prettier '**/*.{md,yml,yaml,json}' --ignore-path .gitignore --ignore-path .prettierignore --check",
        "postlint-fix": "pnpm run prettier-fix",
        "prettier-fix": "prettier '**/*.{md,yml,yaml,json}' --ignore-path .gitignore --ignore-path .prettierignore --write",
        "lint-staged": "lint-staged"
    },
    "dependencies": {
        "next": "16.1.7",
        "normalize.css": "^8.0.1",
        "react": "19.2.4",
        "react-div-100vh": "^0.7.0",
        "react-dom": "19.2.4"
    },
    "devDependencies": {
        "@obusk/eslint-config-next": "^16.1.1",
        "@types/node": "24.10.2",
        "@types/react": "19.2.10",
        "@types/react-dom": "19.2.3",
        "eslint": "^9.39.2",
        "lint-staged": "^16.2.7",
        "prettier": "~3.8.1",
        "simple-git-hooks": "^2.13.1",
        "typescript": "5.9.3"
    }
}
